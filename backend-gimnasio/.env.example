# Configuración del Servidor Node.js
PORT=5001
NODE_ENV=production

# Configuración de la Base de Datos SQL Server (Cloud SQL / Azure SQL / AWS RDS)
DB_USER=cloud_admin
DB_PASSWORD=TuPasswordSeguro123!
DB_SERVER=tu-servidor-sql.database.windows.net
DB_NAME=slimming_gym_db
DB_PORT=1433
# DB_INSTANCE=SQLEXPRESS # Opcional si usas instancia nombrada local

# Seguridad y Autenticación JWT
JWT_SECRET=tu_clave_secreta_jwt_para_produccion_super_segura_2026

# Configuración de Dominio Oficial y CORS
FRONTEND_URL=https://slimminggym.com
ALLOWED_ORIGINS=https://slimminggym.com,https://www.slimminggym.com,http://localhost:5173

# Google Cloud Storage (Para recibos de pago y comprobantes)
GCS_BUCKET_NAME=slimming-gym-storage
GOOGLE_APPLICATION_CREDENTIALS=./config/google-key.json

# Servicio de Correo Electrónico (Nodemailer / SMTP)
EMAIL_SERVICE=gmail
EMAIL_USER=soporte@slimminggym.com
EMAIL_PASS=tu_app_password_o_credencial
